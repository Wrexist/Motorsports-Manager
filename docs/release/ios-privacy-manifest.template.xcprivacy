<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <key>NSPrivacyTracking</key>
    <false/>
    <key>NSPrivacyTrackingDomains</key>
    <array/>
    <key>NSPrivacyCollectedDataTypes</key>
    <array/>
    <key>NSPrivacyAccessedAPITypes</key>
    <array>
      <!--
        IMPORTANT:
        - Only include categories you actually use.
        - Reason strings must match Apple's required-reason API list for your Xcode version.

        Common examples (may or may not apply to Pit Lane Manager):
        - UserDefaults access (Capacitor Preferences on iOS may surface as UserDefaults-like storage)
        - File timestamp APIs if you touch filesystem metadata for saves

        Fill in with real values before App Store submission.
      -->
    </array>
  </dict>
</plist>
